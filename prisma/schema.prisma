generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  ADMIN
  MEMBER
}

enum SequenceEnrollmentStatus {
  ACTIVE
  COMPLETED
  STOPPED
}

enum OutboundMessageStatus {
  QUEUED
  PROCESSING
  SENT
  DEAD_LETTER
}

enum OutboundMessageProvider {
  SMTP
  GMAIL_STUB
}

enum OutboundMessageEventType {
  QUEUED
  SENT
  RETRY_SCHEDULED
  DEAD_LETTER
}

model User {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String       @unique
  passwordHash String
  name        String?
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  memberships Membership[]
}

model Workspace {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  memberships Membership[]
  leads       Lead[]
  tags        Tag[]
  sequences   Sequence[]
  sequenceSteps       SequenceStep[]
  sequenceEnrollments SequenceEnrollment[]
  outboundMessageJobs OutboundMessageJob[]
}

model Membership {
  userId      String         @db.Uuid
  workspaceId String         @db.Uuid
  role        MembershipRole @default(MEMBER)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId, role])
}

model Lead {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  email       String
  company     String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tags        LeadTag[]
  enrollments SequenceEnrollment[]

  @@unique([workspaceId, email])
  @@index([workspaceId, name])
  @@index([workspaceId, company])
  @@index([workspaceId, createdAt])
}

model Sequence {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @db.Uuid
  name        String
  createdAt   DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @db.Timestamptz(6)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
  outboundMessageJobs OutboundMessageJob[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, name])
}

model SequenceStep {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String    @db.Uuid
  sequenceId   String    @db.Uuid
  stepOrder    Int
  delayMinutes Int
  subject      String
  body         String
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequence  Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  outboundMessageJobs OutboundMessageJob[]

  @@unique([sequenceId, stepOrder])
  @@index([workspaceId, sequenceId])
}

model SequenceEnrollment {
  id           String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String                   @db.Uuid
  sequenceId   String                   @db.Uuid
  leadId       String                   @db.Uuid
  status       SequenceEnrollmentStatus @default(ACTIVE)
  currentStep  Int                      @default(0)
  nextSendAt   DateTime?                @db.Timestamptz(6)
  startedAt    DateTime                 @default(now()) @db.Timestamptz(6)
  completedAt  DateTime?                @db.Timestamptz(6)
  stoppedAt    DateTime?                @db.Timestamptz(6)
  createdAt    DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime                 @updatedAt @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequence  Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  outboundMessageJobs OutboundMessageJob[]

  @@unique([sequenceId, leadId])
  @@index([workspaceId, status, nextSendAt])
  @@index([workspaceId, sequenceId, status])
  @@index([workspaceId, leadId])
}

model OutboundMessageJob {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId          String                  @db.Uuid
  sequenceId           String                  @db.Uuid
  sequenceStepId       String                  @db.Uuid
  sequenceEnrollmentId String                  @db.Uuid
  leadId               String                  @db.Uuid
  provider             OutboundMessageProvider @default(SMTP)
  inboxIdentity        String
  toEmail              String
  subject              String
  htmlBody             String
  status               OutboundMessageStatus   @default(QUEUED)
  attemptCount         Int                     @default(0)
  maxAttempts          Int                     @default(3)
  nextAttemptAt        DateTime                @default(now()) @db.Timestamptz(6)
  sentAt               DateTime?               @db.Timestamptz(6)
  deadLetteredAt       DateTime?               @db.Timestamptz(6)
  lastError            String?
  createdAt            DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                @updatedAt @db.Timestamptz(6)

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequence           Sequence             @relation(fields: [sequenceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequenceStep       SequenceStep         @relation(fields: [sequenceStepId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequenceEnrollment SequenceEnrollment   @relation(fields: [sequenceEnrollmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attempts           OutboundMessageAttempt[]
  events             OutboundMessageEvent[]

  @@unique([sequenceEnrollmentId, sequenceStepId])
  @@index([workspaceId, status, nextAttemptAt])
  @@index([inboxIdentity, status, nextAttemptAt])
}

model OutboundMessageAttempt {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outboundMessageId String   @db.Uuid
  attemptNumber    Int
  success          Boolean
  errorMessage     String?
  transientError   Boolean
  providerMessageId String?
  createdAt        DateTime @default(now()) @db.Timestamptz(6)

  outboundMessage OutboundMessageJob @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([outboundMessageId, createdAt])
}

model OutboundMessageEvent {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outboundMessageId String                   @db.Uuid
  type              OutboundMessageEventType
  payload           Json?
  createdAt         DateTime                 @default(now()) @db.Timestamptz(6)

  outboundMessage OutboundMessageJob @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([outboundMessageId, createdAt])
}

model Tag {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leads       LeadTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId, name])
}

model LeadTag {
  leadId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([leadId, tagId])
  @@index([tagId, leadId])
}
