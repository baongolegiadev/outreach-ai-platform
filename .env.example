# Database (Supabase Postgres)
DATABASE_URL=""

# API auth
JWT_SECRET=""
JWT_ACCESS_TTL_SECONDS=""

# Web (Next.js) — browser-visible API base
NEXT_PUBLIC_API_URL=""

# CORS / redirects (Nest)
WEB_ORIGIN=""

# Public API URL (webhooks, links in emails)
API_PUBLIC_URL=""

# API runtime
PORT="3001"
NODE_ENV="development"

# Outbound mailer (SMTP + queue worker)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
OUTBOUND_DEFAULT_FROM_EMAIL="no-reply@example.com"
OUTBOUND_RATE_LIMIT_PER_MINUTE="30"
OUTBOUND_RETRY_BASE_SECONDS="30"
OUTBOUND_WORKER_POLL_MS="5000"
